{
	"name": "construye",
	"version": "0.2.0",
	"description": "Agente de código IA en Cloudflare — open source, gratis, sin configuración",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/construye-lat/construye",
		"directory": "packages/cli"
	},
	"homepage": "https://construye.lat",
	"bugs": {
		"url": "https://github.com/construye-lat/construye/issues"
	},
	"keywords": [
		"ai",
		"coding-agent",
		"cloudflare",
		"workers-ai",
		"cli",
		"llm",
		"developer-tools",
		"code-generation",
		"autonomous-agent",
		"open-source",
		"kimi",
		"qwen",
		"agentic"
	],
	"bin": {
		"construye": "dist/index.js"
	},
	"main": "dist/index.js",
	"files": [
		"dist",
		"README.md"
	],
	"engines": {
		"node": ">=22"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsx src/index.ts",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"@inkjs/ui": "^2.0.0",
		"chalk": "^5.6.2",
		"cli-highlight": "^2.1.11",
		"ink": "^5.1.0",
		"marked": "^15.0.12",
		"marked-terminal": "^7.3.0",
		"react": "^18.3.1"
	},
	"devDependencies": {
		"@construye/core": "workspace:*",
		"@construye/providers": "workspace:*",
		"@construye/shared": "workspace:*",
		"@construye/skills": "workspace:*",
		"@construye/tools": "workspace:*",
		"@types/react": "^18.3.28",
		"ink-testing-library": "^4.0.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0"
	}
}
