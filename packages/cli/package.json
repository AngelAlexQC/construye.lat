{
	"name": "construye",
	"version": "0.2.0",
	"description": "AI coding agent powered by Cloudflare — open source CLI",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/construye-lat/construye",
		"directory": "packages/cli"
	},
	"homepage": "https://construye.lat",
	"keywords": ["ai", "coding-agent", "cloudflare", "cli", "llm", "developer-tools"],
	"bin": {
		"construye": "dist/index.js"
	},
	"main": "dist/index.js",
	"files": ["dist", "README.md"],
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsx src/index.ts",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"chalk": "^5.6.2",
		"cli-highlight": "^2.1.11",
		"ink": "^5.1.0",
		"marked": "^15.0.12",
		"marked-terminal": "^7.3.0",
		"react": "^18.3.1"
	},
	"devDependencies": {
		"@construye/core": "workspace:*",
		"@construye/providers": "workspace:*",
		"@construye/shared": "workspace:*",
		"@construye/skills": "workspace:*",
		"@construye/tools": "workspace:*",
		"@types/react": "^18.3.28",
		"ink-testing-library": "^4.0.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0"
	}
}
