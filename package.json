{
  "name": "construye",
  "private": true,
  "version": "0.1.0",
  "description": "Open source AI coding agent platform on Cloudflare",
  "license": "MIT",
  "repository": "https://github.com/construye-lat/construye",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@construye/cli",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.19.17",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.82.2"
  },
  "dependencies": {
    "marked": "^17.0.6",
    "marked-terminal": "^7.3.0"
  }
}
